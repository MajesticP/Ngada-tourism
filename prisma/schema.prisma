// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id_admin  Int    @id @default(autoincrement())
  username  String @unique
  password  String

  @@map("admin")
}

model Kabupaten {
  id_kabupaten   Int            @id @default(autoincrement())
  nama_kabupaten String
  tempat_wisata  TempatWisata[]

  @@map("kabupaten")
}

model Lokasi {
  id_lokasi     Int            @id @default(autoincrement())
  nama_lokasi   String
  lat           Float?
  lng           Float?
  tempat_wisata TempatWisata[]

  @@map("lokasi")
}

model Galeri {
  id_galeri     Int            @id @default(autoincrement())
  nama_galeri   String
  gambar        String?
  keterangan    String?        @db.Text
  tempat_wisata TempatWisata[]

  @@map("galeri")
}

model TempatWisata {
  id_tempat_wisata   Int       @id @default(autoincrement())
  nama_tempat_wisata String
  alamat             String    @db.Text
  informasi1         String    @db.Text
  kategori           String    @default("wisata_alam")
  id_kabupaten       Int?
  id_lokasi          Int?
  id_galeri          Int?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  kabupaten  Kabupaten? @relation(fields: [id_kabupaten], references: [id_kabupaten])
  lokasi     Lokasi?    @relation(fields: [id_lokasi], references: [id_lokasi])
  galeri     Galeri?    @relation(fields: [id_galeri], references: [id_galeri])
  fotos      Foto[]

  @@map("tempat_wisata")
}

model Pesan {
  id_pesan   Int      @id @default(autoincrement())
  nama       String
  email      String
  subjek     String?
  pesan      String   @db.Text
  sudah_baca Boolean  @default(false)
  created_at DateTime @default(now())

  @@map("pesan")
}

model Foto {
  id_foto          Int          @id @default(autoincrement())
  id_tempat_wisata Int
  url              String       @db.Text
  urutan           Int          @default(0)
  tempat_wisata    TempatWisata @relation(fields: [id_tempat_wisata], references: [id_tempat_wisata], onDelete: Cascade)

  @@map("foto")
}
