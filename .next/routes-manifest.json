      "regex": "^/admin/admins/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/admins/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    },
    {
      "page": "/admin/wisata/[id]/edit",
